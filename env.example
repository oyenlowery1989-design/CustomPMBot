# NoPMsBot v2 — Environment Configuration
# Copy this file to /etc/nopmsbot-v2.env and fill in your values

# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
OWNER_ID=your_telegram_user_id
ADMIN_IDS=your_telegram_user_id
ADMIN_GROUP_ID=-100your_forum_group_id
BROADCAST_TOPIC_NAME=📢 Broadcast

# Database
DB_PATH=/opt/nopmsbot-v2/state.db
MAX_CONCURRENT=15
# Days to keep messages/message_map/terminal-status ai_drafts before the
# daily retention loop deletes them. 0 or negative disables pruning.
DATA_RETENTION_DAYS=180

# Health endpoint — GET returns JSON status (omit to disable)
# HEALTH_PORT=8080

# Stellar verification wallet (public address only — the bot only ever
# needs to read incoming payments to it, never spend from it)
VERIFY_WALLET_PUBLIC=Gxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Encryption key for stored secret keys (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
WALLET_ENCRYPTION_KEY=your_fernet_key_here

# AI-drafted replies (optional — omit to leave the feature unavailable; use /ai on to enable)
# AI_API_KEY=sk-ant-your-anthropic-key
# AI_MODEL=claude-haiku-4-5
